# ── MySQL ──────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=meeting_assistant

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # 비밀번호 없으면 주석 처리

# ── MongoDB ────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=meeting_assistant

# ── ML 모델 ────────────────────────────────────────────────────
ASR_MODEL_PATH=Qwen/Qwen3-ASR-1.7B
ALIGNER_MODEL_PATH=Qwen/Qwen3-ForcedAligner-0.6B
DIARIZE_MODEL_PATH=pyannote/speaker-diarization-community-1
HF_TOKEN=your_huggingface_token
GPU_MEMORY_UTILIZATION=0.55
MAX_MODEL_LEN=4096

# ── 스트리밍 파라미터 ──────────────────────────────────────────
WINDOW_SEC=36
OVERLAP_SEC=6
MAX_ALIGN_SEC=30

# ── Redis 업로드 설정 ──────────────────────────────────────────
REDIS_UPLOAD_INTERVAL_SEC=30
REDIS_TTL_SEC=86400

# ── 화자분리 임계값 ────────────────────────────────────────────
SPEAKER_MATCH_THRESHOLD=1.0
